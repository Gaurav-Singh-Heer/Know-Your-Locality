{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist/prj/browser",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "backend/api.js": {
      "maxDuration": 30
    }
  }
}
